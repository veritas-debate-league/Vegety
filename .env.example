# ---------------------------------------------------------------------------
# Menu data source — Google Apps Script webhook.
#
# These are SERVER-ONLY (no NEXT_PUBLIC_ prefix) so the secret is never shipped
# to the browser. The menu is fetched in a Server Component (lib/fetch-menu.ts).
#
# Copy this file to .env.local and fill in. Leave blank to use built-in mock data.
# Set the SAME values in Vercel → Project → Settings → Environment Variables.
# ---------------------------------------------------------------------------

# The Apps Script Web App /exec URL
MENU_WEBHOOK_URL=

# The shared secret — must equal the WEBHOOK_KEY Script Property in Apps Script.
# Generate it by running setupKey() in apps-script/Code.gs. NEVER commit the real value.
MENU_WEBHOOK_KEY=
